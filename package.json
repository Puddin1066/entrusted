{
  "name": "entrusted-pereira",
  "private": true,
  "description": "Monorepo root. Vercel: Root Directory MUST be \"entrusted\" (Build & Deployment) so .next is at the project root; leave Output Directory empty.",
  "dependencies": {
    "next": "^16.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "scripts": {
    "postinstall": "npm install --prefix entrusted",
    "dev": "npm run dev --prefix entrusted",
    "build": "npm run build --prefix entrusted && node ./scripts/vercel-next-output-root.mjs",
    "start": "npm run start --prefix entrusted",
    "lint": "npm run lint --prefix entrusted"
  }
}
